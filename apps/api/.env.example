DATABASE_URL=postgresql://username:password@localhost:5433/database
PORT=3001

ACCESS_TOKEN_SECRET=replace-with-at-least-32-random-characters
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=7

NODE_ENV=development

WEB_APP_URL="http://localhost:3000"

GOOGLE_CLIENT_ID="replace-with-google-client-id"
GOOGLE_CLIENT_SECRET="replace-with-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/auth/google/callback"

FACEBOOK_APP_ID="replace-with-facebook-app-id"
FACEBOOK_APP_SECRET="replace-with-facebook-app-secret"
FACEBOOK_CALLBACK_URL="http://localhost:3001/auth/facebook/callback"
FACEBOOK_GRAPH_API_VERSION="v24.0"

