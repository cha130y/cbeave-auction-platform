// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  moduleFormat        = "cjs"
  importFileExtension = ""
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum AuthProvider {
  GOOGLE
  FACEBOOK
}

enum AuctionStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  SOLD
  UNSOLD
  CANCELLED
}

enum ParticipantStatus {
  JOINED
  LEFT
}

enum NotificationType {
  OUTBID
  AUCTION_WON
  AUCTION_ENDED
  AUCTION_CANCELLED
}

enum AuctionEventType {
  CREATED
  PUBLISHED
  STARTED
  BID_PLACED
  EXTENDED
  ENDED
  CANCELLED
}

enum AdminActionType {
  SUSPEND_USER
  REACTIVATE_USER
  CREATE_CATEGORY
  UPDATE_CATEGORY
  ACTIVATE_CATEGORY
  DEACTIVATE_CATEGORY
  CANCEL_AUCTION
}

model User {
  id                    String               @id @default(uuid()) @db.Uuid
  email                 String               @unique @db.VarChar(320)
  passwordHash          String?              @map("password_hash") @db.VarChar(255)
  role                  UserRole             @default(USER)
  status                UserStatus           @default(ACTIVE)
  emailVerifiedAt       DateTime?            @map("email_verified_at") @db.Timestamptz()
  lastLoginAt           DateTime?            @map("last_login_at") @db.Timestamptz()
  createdAt             DateTime             @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt             DateTime             @updatedAt @map("updated_at") @db.Timestamptz()
  userProfile           UserProfile?
  authAccounts          AuthAccount[]
  userSessions          UserSession[]
  sellingAuctions       Auction[]            @relation("AuctionSeller")
  wonAuctions           Auction[]            @relation("AuctionWinner")
  watchlists            Watchlist[]
  createCategories      Category[]           @relation("CategoryCreatedByAdmin")
  placedBids            Bid[]
  auctionParticipants   AuctionParticipant[]
  notifications         Notification[]
  performedAdminActions AdminAction[]        @relation("AdminPerformedActions")
  receivedAdminActions  AdminAction[]        @relation("AdminTargetedActions")
  auctionEvents         AuctionEvent[]

  @@index([role, status]) //query role and status
  @@map("users")
}

model UserProfile {
  userId      String   @id @map("user_id") @db.Uuid
  firstName   String   @map("first_name") @db.VarChar(100)
  lastName    String?  @map("last_name") @db.VarChar(100)
  displayName String   @map("display_name") @db.VarChar(80)
  avatarUrl   String?  @map("avatar_url") @db.Text
  bio         String?  @db.VarChar(500)
  phone       String?  @db.VarChar(40)
  location    String?  @db.VarChar(160)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  //index pattern <table>_<columns>_idx
  //It can improve queries that find users by an exact display name
  @@index([displayName])
  @@map("user_profiles")
}

model AuthAccount {
  id                String       @id @default(uuid()) @db.Uuid
  userId            String       @map("user_id") @db.Uuid
  provider          AuthProvider
  providerAccountId String       @map("provider_account_id") @db.VarChar(255)
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@unique([userId, provider])
  @@map("auth_accounts")
}

model UserSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @unique @map("refresh_token_hash") @db.VarChar(255)
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz()
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz()
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt]) //For a maintenance job that deletes expired sessions across all users
  @@map("user_sessions")
}

model Category {
  id               String   @id @default(uuid()) @db.Uuid
  parentId         String?  @map("parent_id") @db.Uuid
  name             String   @db.VarChar(120)
  slug             String   @unique @db.VarChar(140)
  description      String?  @db.VarChar(500)
  isActive         Boolean  @default(true) @map("is_active")
  createdByAdminId String?  @map("created_by_admin_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  parent Category? @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict)

  createdByAdmin User?         @relation("CategoryCreatedByAdmin", fields: [createdByAdminId], references: [id], onDelete: Restrict)
  children       Category[]    @relation("CategoryHierarchy")
  adminActions   AdminAction[]

  auctions Auction[]

  @@index([parentId, isActive])
  @@index([isActive])
  @@map("categories")
}

model Auction {
  id                 String        @id @default(uuid()) @db.Uuid
  sellerId           String        @map("seller_id") @db.Uuid
  categoryId         String        @map("category_id") @db.Uuid
  title              String        @db.VarChar(180)
  description        String
  status             AuctionStatus @default(DRAFT)
  currency           String        @default("USD") @db.Char(3)
  startingPrice      Decimal       @map("starting_price") @db.Decimal(18, 2)
  reservePrice       Decimal?      @map("reserve_price") @db.Decimal(18, 2)
  minBidIncrement    Decimal       @map("min_bid_increment") @db.Decimal(18, 2)
  currentPrice       Decimal       @map("current_price") @db.Decimal(18, 2)
  bidCount           Int           @default(0) @map("bid_count")
  scheduledStartAt   DateTime?     @map("scheduled_start_at") @db.Timestamptz()
  originalEndAt      DateTime?     @map("original_end_at") @db.Timestamptz()
  currentEndAt       DateTime?     @map("current_end_at") @db.Timestamptz()
  publishedAt        DateTime?     @map("published_at") @db.Timestamptz()
  startedAt          DateTime?     @map("started_at") @db.Timestamptz()
  endedAt            DateTime?     @map("ended_at") @db.Timestamptz()
  extensionCount     Int           @default(0) @map("extension_count") @db.SmallInt
  winnerUserId       String?       @map("winner_user_id") @db.Uuid
  winningBidId       String?       @unique @map("winning_bid_id") @db.Uuid
  soldPrice          Decimal?      @map("sold_price") @db.Decimal(18, 2)
  cancellationReason String?       @map("cancellation_reason") @db.VarChar(500)
  rowVersion         Int           @default(1) @map("row_version")
  deletedAt          DateTime?     @map("deleted_at") @db.Timestamptz()
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime      @updatedAt @map("updated_at") @db.Timestamptz()

  winner              User?                @relation("AuctionWinner", fields: [winnerUserId], references: [id], onDelete: Restrict)
  seller              User                 @relation("AuctionSeller", fields: [sellerId], references: [id], onDelete: Restrict)
  bids                Bid[]                @relation("AuctionBids")
  winningBid          Bid?                 @relation("AuctionWinningBid", fields: [winningBidId], references: [id], onDelete: Restrict)
  auctionImages       AuctionImage[]
  watchlists          Watchlist[]
  category            Category             @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  auctionParticipants AuctionParticipant[]
  auctionExtensions   AuctionExtension[]
  notifications       Notification[]
  adminActions        AdminAction[]
  auctionEvents       AuctionEvent[]

  @@index([status, scheduledStartAt])
  @@index([status, currentEndAt])
  @@index([categoryId, status])
  @@index([sellerId, status])
  @@index([status, bidCount]) //Hot auction ranking
  @@map("auctions")
}

model Bid {
  id         String  @id @default(uuid()) @db.Uuid
  auctionId  String  @map("auction_id") @db.Uuid //meaning Bid.auctionId
  bidderId   String  @map("bidder_id") @db.Uuid
  amount     Decimal @db.Decimal(18, 2)
  sequenceNo Int     @map("sequence_no")

  clientRequestId String   @unique @map("client_request_id") @db.Uuid
  placedAt        DateTime @default(now()) @map("placed_at") @db.Timestamptz()

  auction            Auction           @relation("AuctionBids", fields: [auctionId], references: [id], onDelete: Restrict) //references: [id] meaning Auction.id
  wonAuction         Auction?          @relation("AuctionWinningBid") //set ? because initial auction don not have a winner
  bidder             User              @relation(fields: [bidderId], references: [id], onDelete: Restrict)
  triggeredExtension AuctionExtension?
  notifications      Notification[]
  auctionEvents      AuctionEvent[]

  @@unique([auctionId, sequenceNo])
  @@index([auctionId, amount]) //query highest bid for a particular auction
  @@index([bidderId, placedAt]) //query user activity history
  @@map("bids")
}

model AuctionImage {
  id         String   @id @default(uuid()) @db.Uuid
  auctionId  String   @map("auction_id") @db.Uuid
  storageKey String   @unique @map("storage_key") @db.VarChar(500)
  //storageKey : the internal identifier of the image in external file storage
  //ex. auctions/auction-123/images/image-456.webp
  url        String   @db.Text
  //url : location used to display the image ex.https://cdn.cbeave.com/auctions/auction-123/images/image-456.webp
  //The URL may change when you change CDN or storage configuration. The storage key can remain the stable internal identifier 
  altText    String?  @map("alt_text") @db.VarChar(255)
  //short description of the image for accessibility ex. Front view of a red Trek mountain bicycle
  position   Int      @default(0) @db.SmallInt
  //position : controls the order in which images are displayed
  isPrimary  Boolean  @default(false) @map("is_primary")
  //isPrimary : identifies the auction’s cover image used for Homepage auction cards,Search results,Watchlists, Main image on the auction detail page
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Restrict)

  @@unique([auctionId, position])
  @@map("auction_images")
}

model Watchlist {
  userId    String   @map("user_id") @db.Uuid
  auctionId String   @map("auction_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  @@id([userId, auctionId]) //A user can watch many auctions, but cannot watch the same auction twice
  @@index([auctionId, createdAt]) //finding users watching a specific auction, ordered by watch time
  @@map("watchlists")
}

model AuctionParticipant {
  userId     String            @map("user_id") @db.Uuid
  auctionId  String            @map("auction_id") @db.Uuid
  status     ParticipantStatus @default(JOINED)
  joinedAt   DateTime          @default(now()) @map("joined_at") @db.Timestamptz()
  lastSeenAt DateTime?         @map("last_seen_at") @db.Timestamptz()

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  @@id([auctionId, userId]) //one user can have only one participant record for each auction
  @@index([auctionId, status]) //query participants by their state ; ex. 23 participants currently joined
  @@map("auction_participants")
}

model AuctionExtension {
  id               String   @id @default(uuid()) @db.Uuid
  auctionId        String   @map("auction_id") @db.Uuid
  triggeredByBidId String   @unique @map("triggered_by_bid_id") @db.Uuid // set unique to prevent trigger extension in same bid_id due to connection failed
  extensionNumber  Int      @map("extension_number") @db.SmallInt
  previousEndAt    DateTime @map("previous_end_at") @db.Timestamptz()
  newEndAt         DateTime @map("new_end_at") @db.Timestamptz()
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz()

  auction        Auction @relation(fields: [auctionId], references: [id], onDelete: Restrict)
  triggeredByBid Bid     @relation(fields: [triggeredByBidId], references: [id], onDelete: Restrict)

  @@unique([auctionId, extensionNumber])
  @@map("auction_extensions")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  auctionId String           @map("auction_id") @db.Uuid
  bidId     String?          @map("bid_id") @db.Uuid
  type      NotificationType
  title     String           @db.VarChar(180)
  message   String           @db.VarChar(800)
  readAt    DateTime?        @map("read_at") @db.Timestamptz() //timestamp after user read notification
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz()

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Restrict)
  bid     Bid?    @relation(fields: [bidId], references: [id], onDelete: Restrict)

  @@index([userId, readAt, createdAt]) //query user’s unread notifications
  @@map("notifications")
}

model AdminAction {
  id           String          @id @default(uuid()) @db.Uuid
  adminUserId  String          @map("admin_user_id") @db.Uuid
  targetUserId String?         @map("target_user_id") @db.Uuid
  // target is user ==> require userId
  // target are auction or category ==> optional
  auctionId    String?         @map("auction_id") @db.Uuid
  categoryId   String?         @map("category_id") @db.Uuid
  actionType   AdminActionType @map("action_type")
  note         String?         @db.VarChar(1000)
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz()

  adminUser  User      @relation("AdminPerformedActions", fields: [adminUserId], references: [id], onDelete: Restrict)
  targetUser User?     @relation("AdminTargetedActions", fields: [targetUserId], references: [id], onDelete: Restrict)
  auction    Auction?  @relation(fields: [auctionId], references: [id], onDelete: Restrict)
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([adminUserId, createdAt])
  @@index([actionType, createdAt])
  @@map("admin_actions")
}

model AuctionEvent {
  id          Int              @id @default(autoincrement())
  auctionId   String           @map("auction_id") @db.Uuid
  actorUserId String?          @map("actor_user_id") @db.Uuid //some event are caused automatically by the system ex. STARTED ==> Actor is NULL
  bidId       String?          @map("bid_id") @db.Uuid //only some event relate to a bid; ex. BID_PLACED, EXTENDED, ENDED
  // payload     Json?            @db.JsonB
  eventType   AuctionEventType @map("event_type")
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz()

  auction   Auction @relation(fields: [auctionId], references: [id], onDelete: Restrict)
  actorUser User?   @relation(fields: [actorUserId], references: [id], onDelete: Restrict)
  bid       Bid?    @relation(fields: [bidId], references: [id], onDelete: Restrict)

  @@index([auctionId, id])
  @@index([eventType, createdAt]) //query Recent cancellations, Recent auction-ending events, Recent extensions, Recent bid events
  @@map("auction_events")
}
