// CBeave complete future-state ERD — PostgreSQL physical model
// Import into dbdiagram.io
// Scope: Version 1 core plus planned commerce, shipping, seller verification,
// messaging, reviews, multi-vendor storefronts, multi-channel notifications,
// payouts, disputes, and analytics.

Project CBeave_Full_Platform {
  database_type: 'PostgreSQL'
  Note: '''
    Complete future-state schema for CBeave, a multi-vendor real-time auction platform.
    Preview is a UI workflow step and Publish is an application command; neither is a persisted auction status.
    SOLD and UNSOLD normalize the SRS terms Completed and Expired.
    A normal USER account can both buy and sell. ADMIN accounts must never place bids.
  '''
}

Enum user_role {
  USER
  ADMIN
}

Enum user_status {
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

Enum auth_provider {
  LOCAL
  GOOGLE
  FACEBOOK
  APPLE
}

Enum device_platform {
  WEB
  IOS
  ANDROID
}

Enum address_type {
  HOME
  BUSINESS
  RETURN
}

Enum seller_verification_status {
  NOT_STARTED
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  EXPIRED
}

Enum verification_document_type {
  IDENTITY
  ADDRESS
  BUSINESS_REGISTRATION
  TAX_DOCUMENT
  BANK_STATEMENT
  OTHER
}

Enum auction_status {
  DRAFT
  SCHEDULED
  ACTIVE
  SOLD
  UNSOLD
  CANCELLED
}

Enum auction_unsold_reason {
  NO_BIDS
  RESERVE_NOT_MET
  SELLER_CANCELLED
  ADMIN_CANCELLED
  PAYMENT_FAILED
  OTHER
}

Enum item_condition {
  NEW
  LIKE_NEW
  EXCELLENT
  GOOD
  FAIR
  FOR_PARTS
  OTHER
}

Enum bid_status {
  ACCEPTED
  REJECTED
  RETRACTED
}

Enum participant_status {
  RSVP
  JOINED
  LEFT
}

Enum auction_event_type {
  CREATED
  UPDATED
  PUBLISHED
  STARTED
  BID_PLACED
  EXTENDED
  BUY_NOW_TRIGGERED
  ENDED
  CANCELLED
  PAYMENT_PENDING
  PAYMENT_COMPLETED
}

Enum report_status {
  OPEN
  REVIEWING
  RESOLVED
  DISMISSED
}

Enum report_reason {
  PROHIBITED_ITEM
  MISLEADING_CONTENT
  COPYRIGHT
  FRAUD
  HARASSMENT
  OTHER
}

Enum order_status {
  PENDING_PAYMENT
  PAID
  PROCESSING
  PARTIALLY_SHIPPED
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
  REFUNDED
}

Enum order_item_status {
  PENDING_PAYMENT
  PAID
  FULFILLING
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
  REFUNDED
  DISPUTED
}

Enum sale_type {
  AUCTION
  BUY_NOW
}

Enum payment_provider {
  STRIPE
  PAYPAL
  MANUAL
  OTHER
}

Enum payment_status {
  CREATED
  REQUIRES_ACTION
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELLED
  PARTIALLY_REFUNDED
  REFUNDED
}

Enum payment_transaction_type {
  AUTHORIZE
  CAPTURE
  CHARGE
  REFUND
  VOID
  CHARGEBACK
}

Enum transaction_status {
  PENDING
  SUCCEEDED
  FAILED
  CANCELLED
}

Enum refund_status {
  REQUESTED
  REVIEWING
  APPROVED
  PROCESSING
  SUCCEEDED
  REJECTED
  FAILED
}

Enum dispute_status {
  OPEN
  EVIDENCE_REQUIRED
  UNDER_REVIEW
  WON
  LOST
  CLOSED
}

Enum payout_status {
  PENDING
  SCHEDULED
  PROCESSING
  PAID
  FAILED
  CANCELLED
}

Enum shipment_status {
  PENDING
  LABEL_CREATED
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  DELIVERY_FAILED
  RETURNED
  CANCELLED
}

Enum notification_type {
  OUTBID
  AUCTION_STARTING
  AUCTION_STARTED
  BID_ACCEPTED
  AUCTION_WON
  AUCTION_ENDED
  AUCTION_CANCELLED
  PAYMENT_REQUIRED
  PAYMENT_SUCCEEDED
  PAYMENT_FAILED
  ORDER_SHIPPED
  ORDER_DELIVERED
  MESSAGE_RECEIVED
  REVIEW_RECEIVED
  SELLER_VERIFICATION_UPDATED
  PAYOUT_SENT
  DISPUTE_UPDATED
  SYSTEM_ANNOUNCEMENT
}

Enum notification_channel {
  IN_APP
  EMAIL
  PUSH
  SMS
}

Enum delivery_status {
  QUEUED
  SENT
  DELIVERED
  FAILED
  SKIPPED
}

Enum conversation_type {
  DIRECT
  AUCTION
  ORDER
  SUPPORT
}

Enum message_type {
  TEXT
  IMAGE
  FILE
  SYSTEM
}

Enum review_status {
  PUBLISHED
  HIDDEN
  FLAGGED
  REMOVED
}

Enum admin_action_type {
  SUSPEND_USER
  REACTIVATE_USER
  RESET_PASSWORD
  CANCEL_AUCTION
  REINSTATE_AUCTION
  CREATE_CATEGORY
  UPDATE_CATEGORY
  DELETE_CATEGORY
  RESOLVE_REPORT
  APPROVE_SELLER
  REJECT_SELLER
  RESOLVE_DISPUTE
  REFUND_ORDER
  ADJUST_PAYOUT
}

Enum analytics_entity_type {
  PLATFORM
  USER
  SELLER
  AUCTION
  ORDER
  STOREFRONT
}

// -----------------------------------------------------------------------------
// Identity, access, profiles, and seller trust
// -----------------------------------------------------------------------------

Table users {
  id uuid [pk, default: `gen_random_uuid()`]
  email varchar(320) [not null, unique]
  password_hash varchar(255) [note: 'Nullable for social-only accounts']
  role user_role [not null, default: 'USER']
  status user_status [not null, default: 'ACTIVE']
  email_verified_at timestamptz
  last_login_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (role, status)
  }
}

Table user_profiles {
  user_id uuid [pk, ref: - users.id]
  full_name varchar(160) [not null]
  display_name varchar(80) [not null]
  avatar_url text
  bio varchar(500)
  phone varchar(40)
  locale varchar(12) [not null, default: 'en']
  timezone varchar(64) [not null, default: 'UTC']
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    display_name
  }
}

Table auth_accounts {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id uuid [not null, ref: > users.id]
  provider auth_provider [not null]
  provider_account_id varchar(255) [not null]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (provider, provider_account_id) [unique]
    (user_id, provider) [unique]
  }
}

Table user_sessions {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id uuid [not null, ref: > users.id]
  refresh_token_hash varchar(255) [not null, unique]
  ip_address inet
  user_agent text
  expires_at timestamptz [not null]
  revoked_at timestamptz
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (user_id, expires_at)
  }
}

Table password_reset_tokens {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id uuid [not null, ref: > users.id]
  token_hash varchar(255) [not null, unique]
  expires_at timestamptz [not null]
  used_at timestamptz
  created_at timestamptz [not null, default: `now()`]
}

Table email_verification_tokens {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id uuid [not null, ref: > users.id]
  token_hash varchar(255) [not null, unique]
  expires_at timestamptz [not null]
  used_at timestamptz
  created_at timestamptz [not null, default: `now()`]
}

Table user_devices {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id uuid [not null, ref: > users.id]
  platform device_platform [not null]
  device_name varchar(120)
  push_token varchar(512) [unique]
  last_seen_at timestamptz
  revoked_at timestamptz
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (user_id, platform)
  }
}

Table user_addresses {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id uuid [not null, ref: > users.id]
  type address_type [not null, default: 'HOME']
  label varchar(80)
  recipient_name varchar(160) [not null]
  phone varchar(40)
  line1 varchar(200) [not null]
  line2 varchar(200)
  city varchar(120) [not null]
  region varchar(120)
  postal_code varchar(30)
  country_code char(2) [not null]
  is_default_shipping boolean [not null, default: false]
  is_default_billing boolean [not null, default: false]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (user_id, type)
  }
}

Table seller_profiles {
  user_id uuid [pk, ref: - users.id]
  public_name varchar(120) [not null]
  about text
  verification_status seller_verification_status [not null, default: 'NOT_STARTED']
  average_rating decimal(3,2) [not null, default: 0]
  rating_count int [not null, default: 0]
  total_sales int [not null, default: 0]
  payout_provider_account_id varchar(255)
  approved_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
}

Table seller_verification_cases {
  id uuid [pk, default: `gen_random_uuid()`]
  seller_user_id uuid [not null, ref: > seller_profiles.user_id]
  status seller_verification_status [not null, default: 'PENDING']
  submitted_at timestamptz
  reviewed_by_admin_id uuid [ref: > users.id]
  reviewed_at timestamptz
  rejection_reason varchar(1000)
  expires_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (seller_user_id, status)
    (status, submitted_at)
  }
}

Table seller_verification_documents {
  id uuid [pk, default: `gen_random_uuid()`]
  verification_case_id uuid [not null, ref: > seller_verification_cases.id]
  type verification_document_type [not null]
  storage_key varchar(500) [not null, unique]
  file_url text [not null]
  reviewed_at timestamptz
  created_at timestamptz [not null, default: `now()`]
}

// -----------------------------------------------------------------------------
// Auction catalogue and real-time bidding
// -----------------------------------------------------------------------------

Table categories {
  id uuid [pk, default: `gen_random_uuid()`]
  parent_id uuid [ref: > categories.id]
  name varchar(120) [not null]
  slug varchar(140) [not null, unique]
  description varchar(500)
  is_active boolean [not null, default: true]
  created_by_admin_id uuid [ref: > users.id]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    parent_id
    is_active
  }
}

Table tags {
  id uuid [pk, default: `gen_random_uuid()`]
  name varchar(80) [not null, unique]
  slug varchar(100) [not null, unique]
  created_at timestamptz [not null, default: `now()`]
}

Table auctions {
  id uuid [pk, default: `gen_random_uuid()`]
  seller_id uuid [not null, ref: > users.id]
  category_id uuid [not null, ref: > categories.id]
  ships_from_address_id uuid [ref: > user_addresses.id]
  title varchar(180) [not null]
  description text [not null]
  condition item_condition [not null, default: 'OTHER']
  status auction_status [not null, default: 'DRAFT']
  unsold_reason auction_unsold_reason
  currency char(3) [not null, default: 'USD']
  starting_price decimal(18,2) [not null]
  reserve_price decimal(18,2) [note: 'Private: never expose this amount to buyers']
  buy_now_price decimal(18,2)
  min_bid_increment decimal(18,2) [not null]
  current_price decimal(18,2) [not null]
  bid_count int [not null, default: 0]
  scheduled_start_at timestamptz
  original_end_at timestamptz
  current_end_at timestamptz
  published_at timestamptz
  started_at timestamptz
  ended_at timestamptz
  extension_count smallint [not null, default: 0, note: 'Maximum 5']
  reserve_met_at timestamptz
  winner_user_id uuid [ref: > users.id]
  winning_bid_id uuid
  sold_price decimal(18,2)
  is_featured boolean [not null, default: false]
  allows_shipping boolean [not null, default: true]
  allows_local_pickup boolean [not null, default: false]
  cancellation_reason varchar(500)
  row_version int [not null, default: 1]
  deleted_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (status, scheduled_start_at)
    (status, current_end_at)
    (category_id, status)
    (seller_id, status)
    is_featured
  }
}

Table auction_tags {
  auction_id uuid [not null, ref: > auctions.id]
  tag_id uuid [not null, ref: > tags.id]

  indexes {
    (auction_id, tag_id) [pk]
    tag_id
  }
}

Table auction_images {
  id uuid [pk, default: `gen_random_uuid()`]
  auction_id uuid [not null, ref: > auctions.id]
  storage_key varchar(500) [not null, unique]
  url text [not null]
  alt_text varchar(255)
  position smallint [not null, default: 0]
  is_primary boolean [not null, default: false]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (auction_id, position) [unique]
  }
}

Table bids {
  id uuid [pk, default: `gen_random_uuid()`]
  auction_id uuid [not null, ref: > auctions.id]
  bidder_id uuid [not null, ref: > users.id]
  amount decimal(18,2) [not null]
  sequence_no int [not null]
  status bid_status [not null, default: 'ACCEPTED']
  rejection_reason varchar(255)
  client_request_id uuid [not null, unique, note: 'Idempotency key']
  placed_at timestamptz [not null, default: `now()`]

  indexes {
    (auction_id, sequence_no) [unique]
    (auction_id, amount)
    (bidder_id, placed_at)
  }
}

Ref: auctions.winning_bid_id > bids.id

Table watchlists {
  user_id uuid [not null, ref: > users.id]
  auction_id uuid [not null, ref: > auctions.id]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (user_id, auction_id) [pk]
    (auction_id, created_at)
  }
}

Table auction_participants {
  auction_id uuid [not null, ref: > auctions.id]
  user_id uuid [not null, ref: > users.id]
  status participant_status [not null, default: 'JOINED']
  joined_at timestamptz [not null, default: `now()`]
  last_seen_at timestamptz

  indexes {
    (auction_id, user_id) [pk]
    (auction_id, status)
  }
}

Table auction_extensions {
  id uuid [pk, default: `gen_random_uuid()`]
  auction_id uuid [not null, ref: > auctions.id]
  triggered_by_bid_id uuid [not null, ref: - bids.id]
  extension_number smallint [not null]
  previous_end_at timestamptz [not null]
  new_end_at timestamptz [not null]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (auction_id, extension_number) [unique]
  }
}

Table auction_events {
  id bigint [pk, increment]
  auction_id uuid [not null, ref: > auctions.id]
  actor_user_id uuid [ref: > users.id]
  bid_id uuid [ref: > bids.id]
  event_type auction_event_type [not null]
  payload jsonb
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (auction_id, id)
    (event_type, created_at)
  }
}

// -----------------------------------------------------------------------------
// Orders, payments, refunds, disputes, and seller payouts
// -----------------------------------------------------------------------------

Table orders {
  id uuid [pk, default: `gen_random_uuid()`]
  order_number varchar(32) [not null, unique]
  buyer_id uuid [not null, ref: > users.id]
  status order_status [not null, default: 'PENDING_PAYMENT']
  currency char(3) [not null]
  subtotal decimal(18,2) [not null]
  buyer_fee_total decimal(18,2) [not null, default: 0]
  tax_total decimal(18,2) [not null, default: 0]
  shipping_total decimal(18,2) [not null, default: 0]
  discount_total decimal(18,2) [not null, default: 0]
  grand_total decimal(18,2) [not null]
  payment_due_at timestamptz
  paid_at timestamptz
  completed_at timestamptz
  cancelled_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (buyer_id, created_at)
    (status, payment_due_at)
  }
}

Table order_addresses {
  id uuid [pk, default: `gen_random_uuid()`]
  order_id uuid [not null, ref: > orders.id]
  kind varchar(16) [not null, note: 'SHIPPING or BILLING snapshot']
  recipient_name varchar(160) [not null]
  phone varchar(40)
  line1 varchar(200) [not null]
  line2 varchar(200)
  city varchar(120) [not null]
  region varchar(120)
  postal_code varchar(30)
  country_code char(2) [not null]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (order_id, kind) [unique]
  }
}

Table order_items {
  id uuid [pk, default: `gen_random_uuid()`]
  order_id uuid [not null, ref: > orders.id]
  auction_id uuid [not null, ref: - auctions.id]
  seller_id uuid [not null, ref: > users.id]
  sale_type sale_type [not null]
  status order_item_status [not null, default: 'PENDING_PAYMENT']
  unit_price decimal(18,2) [not null]
  buyer_fee decimal(18,2) [not null, default: 0]
  seller_fee decimal(18,2) [not null, default: 0]
  tax_amount decimal(18,2) [not null, default: 0]
  shipping_amount decimal(18,2) [not null, default: 0]
  seller_net_amount decimal(18,2) [not null]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    auction_id [unique]
    (order_id, seller_id)
    (seller_id, status)
  }
}

Table payment_intents {
  id uuid [pk, default: `gen_random_uuid()`]
  order_id uuid [not null, ref: > orders.id]
  provider payment_provider [not null]
  provider_reference varchar(255)
  status payment_status [not null, default: 'CREATED']
  amount decimal(18,2) [not null]
  currency char(3) [not null]
  idempotency_key uuid [not null, unique]
  failure_code varchar(120)
  failure_message varchar(500)
  expires_at timestamptz
  succeeded_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (order_id, status)
    (provider, provider_reference)
  }
}

Table payment_transactions {
  id uuid [pk, default: `gen_random_uuid()`]
  payment_intent_id uuid [not null, ref: > payment_intents.id]
  type payment_transaction_type [not null]
  status transaction_status [not null]
  provider_transaction_id varchar(255)
  amount decimal(18,2) [not null]
  currency char(3) [not null]
  provider_payload jsonb
  processed_at timestamptz
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (payment_intent_id, created_at)
    provider_transaction_id
  }
}

Table refunds {
  id uuid [pk, default: `gen_random_uuid()`]
  order_item_id uuid [not null, ref: > order_items.id]
  payment_transaction_id uuid [ref: > payment_transactions.id]
  requested_by_user_id uuid [not null, ref: > users.id]
  reviewed_by_admin_id uuid [ref: > users.id]
  status refund_status [not null, default: 'REQUESTED']
  amount decimal(18,2) [not null]
  reason varchar(1000) [not null]
  provider_refund_id varchar(255)
  resolved_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (order_item_id, status)
    (status, created_at)
  }
}

Table disputes {
  id uuid [pk, default: `gen_random_uuid()`]
  order_item_id uuid [not null, ref: > order_items.id]
  opened_by_user_id uuid [not null, ref: > users.id]
  assigned_admin_id uuid [ref: > users.id]
  status dispute_status [not null, default: 'OPEN']
  reason varchar(1000) [not null]
  evidence jsonb
  resolution_note varchar(1000)
  opened_at timestamptz [not null, default: `now()`]
  resolved_at timestamptz
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (status, opened_at)
    (order_item_id, status)
  }
}

Table payouts {
  id uuid [pk, default: `gen_random_uuid()`]
  seller_id uuid [not null, ref: > users.id]
  provider payment_provider [not null]
  provider_payout_id varchar(255)
  status payout_status [not null, default: 'PENDING']
  currency char(3) [not null]
  gross_amount decimal(18,2) [not null]
  fee_amount decimal(18,2) [not null, default: 0]
  adjustment_amount decimal(18,2) [not null, default: 0]
  net_amount decimal(18,2) [not null]
  scheduled_for timestamptz
  paid_at timestamptz
  failure_reason varchar(500)
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (seller_id, status, created_at)
  }
}

Table payout_items {
  payout_id uuid [not null, ref: > payouts.id]
  order_item_id uuid [not null, ref: > order_items.id]
  gross_amount decimal(18,2) [not null]
  seller_fee decimal(18,2) [not null]
  refund_adjustment decimal(18,2) [not null, default: 0]
  net_amount decimal(18,2) [not null]

  indexes {
    (payout_id, order_item_id) [pk]
    order_item_id [unique]
  }
}

// -----------------------------------------------------------------------------
// Shipping and fulfilment
// -----------------------------------------------------------------------------

Table shipments {
  id uuid [pk, default: `gen_random_uuid()`]
  order_item_id uuid [not null, ref: > order_items.id]
  seller_address_id uuid [ref: > user_addresses.id]
  destination_order_address_id uuid [not null, ref: > order_addresses.id]
  status shipment_status [not null, default: 'PENDING']
  carrier varchar(120)
  service_level varchar(120)
  tracking_number varchar(255)
  tracking_url text
  shipped_at timestamptz
  delivered_at timestamptz
  estimated_delivery_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (order_item_id, status)
    tracking_number
  }
}

Table shipping_labels {
  id uuid [pk, default: `gen_random_uuid()`]
  shipment_id uuid [not null, ref: - shipments.id]
  provider varchar(120)
  label_url text [not null]
  label_format varchar(20)
  cost decimal(18,2)
  currency char(3)
  voided_at timestamptz
  created_at timestamptz [not null, default: `now()`]
}

Table shipment_events {
  id bigint [pk, increment]
  shipment_id uuid [not null, ref: > shipments.id]
  status shipment_status [not null]
  location varchar(255)
  description varchar(500)
  occurred_at timestamptz [not null]
  raw_payload jsonb
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (shipment_id, occurred_at)
  }
}

// -----------------------------------------------------------------------------
// Messaging, notifications, and reviews
// -----------------------------------------------------------------------------

Table conversations {
  id uuid [pk, default: `gen_random_uuid()`]
  type conversation_type [not null]
  auction_id uuid [ref: > auctions.id]
  order_id uuid [ref: > orders.id]
  subject varchar(180)
  created_by_user_id uuid [not null, ref: > users.id]
  closed_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    auction_id
    order_id
  }
}

Table conversation_participants {
  conversation_id uuid [not null, ref: > conversations.id]
  user_id uuid [not null, ref: > users.id]
  joined_at timestamptz [not null, default: `now()`]
  last_read_at timestamptz
  muted_at timestamptz
  left_at timestamptz

  indexes {
    (conversation_id, user_id) [pk]
    (user_id, last_read_at)
  }
}

Table messages {
  id uuid [pk, default: `gen_random_uuid()`]
  conversation_id uuid [not null, ref: > conversations.id]
  sender_user_id uuid [ref: > users.id, note: 'Null for system messages']
  type message_type [not null, default: 'TEXT']
  body text
  edited_at timestamptz
  deleted_at timestamptz
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (conversation_id, created_at)
    (sender_user_id, created_at)
  }
}

Table message_attachments {
  id uuid [pk, default: `gen_random_uuid()`]
  message_id uuid [not null, ref: > messages.id]
  storage_key varchar(500) [not null, unique]
  file_url text [not null]
  file_name varchar(255) [not null]
  mime_type varchar(120) [not null]
  size_bytes bigint [not null]
  created_at timestamptz [not null, default: `now()`]
}

Table notifications {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id uuid [not null, ref: > users.id]
  auction_id uuid [ref: > auctions.id]
  bid_id uuid [ref: > bids.id]
  order_id uuid [ref: > orders.id]
  conversation_id uuid [ref: > conversations.id]
  type notification_type [not null]
  title varchar(180) [not null]
  message varchar(800) [not null]
  payload jsonb
  read_at timestamptz
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (user_id, read_at, created_at)
  }
}

Table notification_preferences {
  user_id uuid [not null, ref: > users.id]
  type notification_type [not null]
  channel notification_channel [not null]
  enabled boolean [not null, default: true]
  quiet_hours_start time
  quiet_hours_end time
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (user_id, type, channel) [pk]
  }
}

Table notification_deliveries {
  id uuid [pk, default: `gen_random_uuid()`]
  notification_id uuid [not null, ref: > notifications.id]
  channel notification_channel [not null]
  status delivery_status [not null, default: 'QUEUED']
  provider varchar(120)
  provider_message_id varchar(255)
  attempt_count smallint [not null, default: 0]
  last_error varchar(1000)
  sent_at timestamptz
  delivered_at timestamptz
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (notification_id, channel) [unique]
    (status, created_at)
  }
}

Table reviews {
  id uuid [pk, default: `gen_random_uuid()`]
  order_item_id uuid [not null, ref: > order_items.id]
  reviewer_user_id uuid [not null, ref: > users.id]
  reviewee_user_id uuid [not null, ref: > users.id]
  rating smallint [not null, note: '1 to 5']
  title varchar(160)
  comment varchar(2000)
  status review_status [not null, default: 'PUBLISHED']
  seller_response varchar(1000)
  seller_responded_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (order_item_id, reviewer_user_id) [unique]
    (reviewee_user_id, status, created_at)
  }
}

// -----------------------------------------------------------------------------
// Storefronts and seller merchandising
// -----------------------------------------------------------------------------

Table storefronts {
  id uuid [pk, default: `gen_random_uuid()`]
  seller_user_id uuid [not null, unique, ref: - seller_profiles.user_id]
  name varchar(140) [not null]
  slug varchar(160) [not null, unique]
  tagline varchar(220)
  description text
  logo_url text
  banner_url text
  accent_color varchar(16)
  is_published boolean [not null, default: false]
  published_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
}

Table storefront_followers {
  storefront_id uuid [not null, ref: > storefronts.id]
  user_id uuid [not null, ref: > users.id]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (storefront_id, user_id) [pk]
    (user_id, created_at)
  }
}

Table storefront_collections {
  id uuid [pk, default: `gen_random_uuid()`]
  storefront_id uuid [not null, ref: > storefronts.id]
  name varchar(120) [not null]
  slug varchar(140) [not null]
  description varchar(500)
  position smallint [not null, default: 0]
  is_visible boolean [not null, default: true]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (storefront_id, slug) [unique]
    (storefront_id, position)
  }
}

Table storefront_collection_auctions {
  collection_id uuid [not null, ref: > storefront_collections.id]
  auction_id uuid [not null, ref: > auctions.id]
  position smallint [not null, default: 0]
  added_at timestamptz [not null, default: `now()`]

  indexes {
    (collection_id, auction_id) [pk]
    (collection_id, position)
  }
}

// -----------------------------------------------------------------------------
// Moderation, audit, and reporting
// -----------------------------------------------------------------------------

Table auction_reports {
  id uuid [pk, default: `gen_random_uuid()`]
  auction_id uuid [not null, ref: > auctions.id]
  reporter_id uuid [not null, ref: > users.id]
  reason report_reason [not null]
  details varchar(1000)
  status report_status [not null, default: 'OPEN']
  reviewed_by_admin_id uuid [ref: > users.id]
  reviewed_at timestamptz
  resolution_note varchar(1000)
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (status, created_at)
    (auction_id, status)
  }
}

Table admin_actions {
  id uuid [pk, default: `gen_random_uuid()`]
  admin_user_id uuid [not null, ref: > users.id]
  target_user_id uuid [ref: > users.id]
  auction_id uuid [ref: > auctions.id]
  category_id uuid [ref: > categories.id]
  order_id uuid [ref: > orders.id]
  dispute_id uuid [ref: > disputes.id]
  verification_case_id uuid [ref: > seller_verification_cases.id]
  action_type admin_action_type [not null]
  note varchar(1000)
  metadata jsonb
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (admin_user_id, created_at)
    (action_type, created_at)
  }
}

// -----------------------------------------------------------------------------
// Product and business analytics (OLTP-friendly aggregates)
// -----------------------------------------------------------------------------

Table analytics_events {
  id bigint [pk, increment]
  actor_user_id uuid [ref: > users.id]
  session_id uuid
  entity_type analytics_entity_type [not null]
  entity_id uuid
  event_name varchar(120) [not null]
  properties jsonb
  occurred_at timestamptz [not null, default: `now()`]

  indexes {
    (event_name, occurred_at)
    (entity_type, entity_id, occurred_at)
    (actor_user_id, occurred_at)
  }
}

Table auction_daily_metrics {
  auction_id uuid [not null, ref: > auctions.id]
  metric_date date [not null]
  detail_views int [not null, default: 0]
  unique_viewers int [not null, default: 0]
  watchlist_adds int [not null, default: 0]
  lobby_joins int [not null, default: 0]
  bids_placed int [not null, default: 0]
  unique_bidders int [not null, default: 0]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (auction_id, metric_date) [pk]
    metric_date
  }
}

Table seller_daily_metrics {
  seller_user_id uuid [not null, ref: > users.id]
  metric_date date [not null]
  active_auctions int [not null, default: 0]
  auctions_sold int [not null, default: 0]
  gross_sales decimal(18,2) [not null, default: 0]
  net_payouts decimal(18,2) [not null, default: 0]
  profile_views int [not null, default: 0]
  storefront_views int [not null, default: 0]
  new_followers int [not null, default: 0]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (seller_user_id, metric_date) [pk]
    metric_date
  }
}

Table platform_daily_metrics {
  metric_date date [pk]
  registered_users int [not null, default: 0]
  verified_sellers int [not null, default: 0]
  auctions_created int [not null, default: 0]
  auctions_sold int [not null, default: 0]
  bids_placed int [not null, default: 0]
  gross_merchandise_value decimal(18,2) [not null, default: 0]
  platform_revenue decimal(18,2) [not null, default: 0]
  created_at timestamptz [not null, default: `now()`]
}

TableGroup identity_and_trust {
  users
  user_profiles
  auth_accounts
  user_sessions
  password_reset_tokens
  email_verification_tokens
  user_devices
  user_addresses
  seller_profiles
  seller_verification_cases
  seller_verification_documents
}

TableGroup auction_core {
  categories
  tags
  auctions
  auction_tags
  auction_images
  bids
  watchlists
  auction_participants
  auction_extensions
  auction_events
}

TableGroup commerce {
  orders
  order_addresses
  order_items
  payment_intents
  payment_transactions
  refunds
  disputes
  payouts
  payout_items
}

TableGroup fulfilment {
  shipments
  shipping_labels
  shipment_events
}

TableGroup communication_and_reputation {
  conversations
  conversation_participants
  messages
  message_attachments
  notifications
  notification_preferences
  notification_deliveries
  reviews
}

TableGroup storefronts_and_merchandising {
  storefronts
  storefront_followers
  storefront_collections
  storefront_collection_auctions
}

TableGroup governance {
  auction_reports
  admin_actions
}

TableGroup analytics {
  analytics_events
  auction_daily_metrics
  seller_daily_metrics
  platform_daily_metrics
}
