digraph cbeave_v1 {
  graph [rankdir=LR, bgcolor="#f8fafc", nodesep=0.5, ranksep=1.0];
  node [shape=record, style="rounded,filled", fillcolor="white", color="#94a3b8", fontname="Arial"];
  edge [color="#64748b", fontname="Arial", fontsize=9];
  users [label="{users|id : uuid|email : text|password_hash : text|role : user_role|status : user_status|email_verified_at : timestamptz|last_login_at : timestamptz|created_at : timestamptz|updated_at : timestamptz}"];
  user_profiles [label="{user_profiles|user_id : uuid|first_name : varchar(100)|last_name : varchar(100)|display_name : varchar(80)|avatar_url : text|bio : varchar(500)|phone : varchar(40)|location : varchar(160)|created_at : timestamptz|updated_at : timestamptz}"];
  auth_accounts [label="{auth_accounts|id : uuid|user_id : uuid|provider : auth_provider|provider_account_id : varchar(255)|created_at : timestamptz}"];
  user_sessions [label="{user_sessions|id : uuid|user_id : uuid|refresh_token_hash : varchar(255)|expires_at : timestamptz|revoked_at : timestamptz|created_at : timestamptz}"];
  categories [label="{categories|id : uuid|parent_id : uuid|name : varchar(120)|slug : varchar(140)|description : varchar(500)|is_active : boolean|created_by_admin_id : uuid|created_at : timestamptz|updated_at : timestamptz}"];
  auctions [label="{auctions|id : uuid|seller_id : uuid|category_id : uuid|title : varchar(180)|description : text|status : auction_status|currency : char(3)|starting_price : decimal(18,2)|reserve_price : decimal(18,2)|min_bid_increment : decimal(18,2)|current_price : decimal(18,2)|bid_count : int|scheduled_start_at : timestamptz|original_end_at : timestamptz|current_end_at : timestamptz|published_at : timestamptz|started_at : timestamptz|ended_at : timestamptz|extension_count : smallint|winner_user_id : uuid|winning_bid_id : uuid|sold_price : decimal(18,2)|cancellation_reason : varchar(500)|row_version : int|deleted_at : timestamptz|created_at : timestamptz|updated_at : timestamptz}"];
  bids [label="{bids|id : uuid|auction_id : uuid|bidder_id : uuid|amount : decimal(18,2)|sequence_no : int|client_request_id : uuid|placed_at : timestamptz}"];
  auction_images [label="{auction_images|id : uuid|auction_id : uuid|storage_key : varchar(500)|url : text|alt_text : varchar(255)|position : smallint|is_primary : boolean|created_at : timestamptz}"];
  watchlists [label="{watchlists|user_id : uuid|auction_id : uuid|created_at : timestamptz}"];
  auction_participants [label="{auction_participants|auction_id : uuid|user_id : uuid|status : participant_status|joined_at : timestamptz|last_seen_at : timestamptz}"];
  auction_extensions [label="{auction_extensions|id : uuid|auction_id : uuid|triggered_by_bid_id : uuid|extension_number : smallint|previous_end_at : timestamptz|new_end_at : timestamptz|created_at : timestamptz}"];
  notifications [label="{notifications|id : uuid|user_id : uuid|auction_id : uuid|bid_id : uuid|type : notification_type|title : varchar(180)|message : varchar(800)|read_at : timestamptz|created_at : timestamptz}"];
  admin_actions [label="{admin_actions|id : uuid|admin_user_id : uuid|target_user_id : uuid|auction_id : uuid|category_id : uuid|action_type : admin_action_type|note : varchar(1000)|created_at : timestamptz}"];
  auction_events [label="{auction_events|id : int|auction_id : uuid|actor_user_id : uuid|bid_id : uuid|event_type : auction_event_type|created_at : timestamptz}"];
  user_profiles -> users;
  auth_accounts -> users;
  user_sessions -> users;
  categories -> users;
  auctions -> users;
  auctions -> categories;
  bids -> users;
  bids -> auctions;
  auction_images -> auctions;
  watchlists -> users;
  watchlists -> auctions;
  auction_participants -> users;
  auction_participants -> auctions;
  auction_extensions -> auctions;
  auction_extensions -> bids;
  notifications -> users;
  notifications -> auctions;
  notifications -> bids;
  admin_actions -> users;
  admin_actions -> auctions;
  admin_actions -> categories;
  auction_events -> auctions;
  auction_events -> users;
  auction_events -> bids;
}